# ─────────────────────────────────────────────────────────────────────────────
# Code Context Engine — environment configuration
# Copy to .env and fill in values. All settings have working defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paths ────────────────────────────────────────────────────────────────────
CCE_PATHS__DATA_DIR=.cce
CCE_PATHS__SQLITE_DB=.cce/index.sqlite
CCE_PATHS__QDRANT_PATH=.cce/qdrant
CCE_PATHS__AGENT_CHECKPOINT=.cce/agent.sqlite

# ── Embeddings ───────────────────────────────────────────────────────────────
# OPTION A (default) — OpenAI text-embedding-3-large (3072d, best quality, needs API key)
CCE_EMBED__BACKEND=openai
CCE_EMBED__MODEL_NAME=text-embedding-3-large
# CCE_EMBED__DIM=3072              # auto-detected; override only if you know what you're doing
# OPENAI_API_KEY=sk-...

# OPTION B — OpenAI text-embedding-3-small (1536d, cheap & fast)
# CCE_EMBED__BACKEND=openai
# CCE_EMBED__MODEL_NAME=text-embedding-3-small
# CCE_EMBED__DIM=1536
# OPENAI_API_KEY=sk-...

# OPTION C — Jina v2 code, CPU-friendly, no API key, ~550MB model
# CCE_EMBED__BACKEND=jina
# CCE_EMBED__MODEL_NAME=jinaai/jina-embeddings-v2-base-code
# CCE_EMBED__DIM=768
# CCE_EMBED__BATCH_SIZE=32        # increase for GPU, decrease for low-RAM CPU
# CCE_EMBED__MAX_TOKENS=8192

# OPTION D — nomic-embed-code (3584d, best offline quality, ~7GB VRAM)
# CCE_EMBED__BACKEND=nomic
# CCE_EMBED__MODEL_NAME=nomic-ai/nomic-embed-code
# CCE_EMBED__DIM=3584
# CCE_EMBED__DEVICE=cuda          # cuda | cpu | mps | auto
# CCE_EMBED__DTYPE=fp16

# ── Qdrant vector store ────────────────────────────────────────────────────────
# CCE_QDRANT__MODE=embedded        # embedded (local file) | remote
CCE_QDRANT__MODE=remote            # remote  → run docker on host port 6336
CCE_QDRANT__URL=http://localhost:6336
# CCE_QDRANT__URL=http://localhost:6333
# CCE_QDRANT__API_KEY=

# ── Agent / LLM ───────────────────────────────────────────────────────────────
CCE_AGENT__LLM_PROVIDER=openai   # openai | anthropic | ollama
CCE_AGENT__LLM_MODEL=gpt-5.4-mini-2026-03-17
# CCE_AGENT__LLM_MODEL=gpt-4o-mini
# CCE_AGENT__LLM_MODEL=claude-3-5-haiku-20241022    # for anthropic
# CCE_AGENT__LLM_MODEL=qwen2.5-coder:7b             # for ollama
CCE_AGENT__LLM_TEMPERATURE=0.0
CCE_AGENT__MAX_RETRIEVAL_LOOPS=3
CCE_AGENT__CHECKPOINTER=sqlite   # sqlite | memory
CCE_AGENT__STREAM_EVENTS=true
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
CCE_SERVER__HOST=127.0.0.1
CCE_SERVER__PORT=8765
# CCE_SERVER__CORS_ORIGINS=["*"]   # JSON array of allowed origins

# ── Top-level ─────────────────────────────────────────────────────────────────
CCE_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
CCE_SCHEMA_VERSION=1             # bump to force a full index rebuild
